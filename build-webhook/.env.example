# Puerto del servicio webhook
PORT=3002

# Token de seguridad para autenticar las peticiones desde Spring
# IMPORTANTE: Genera un token seguro y compártelo entre Spring y este servicio
WEBHOOK_SECRET_TOKEN=your-secret-token-here

# Modo de desarrollo (development o production)
NODE_ENV=development

# Permitir CORS desde el backend Spring
ALLOWED_ORIGINS=http://localhost:8080,http://92.186.195.152:8080
